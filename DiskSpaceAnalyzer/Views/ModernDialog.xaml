<Window x:Class="DiskSpaceAnalyzer.Views.ModernDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:DiskSpaceAnalyzer.ViewModels"
        xmlns:converters="clr-namespace:DiskSpaceAnalyzer.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}"
        SizeToContent="Height"
        Width="500"
        MinHeight="200" MaxHeight="600"
        MinWidth="400" MaxWidth="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance viewModels:ModernDialogViewModel}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/RobocopyStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer shadow container -->
    <Border Background="Transparent" Padding="10" Opacity="0" x:Name="RootBorder">
        <Border Background="#FF1E1E1E"
                BorderBrush="#FF555555"
                BorderThickness="1"
                CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.5" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Colored accent bar -->
                <Border Grid.Column="0"
                        CornerRadius="8,0,0,8"
                        Background="{Binding AccentColor}" />

                <!-- Main content -->
                <Grid Grid.Column="1" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header with icon and title -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0"
                                Width="48"
                                Height="48"
                                CornerRadius="24"
                                Background="#FF2D2D30"
                                Margin="0,0,15,0">
                            <TextBlock Text="{Binding Icon}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding AccentColor}" />
                        </Border>

                        <!-- Title -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Title}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#FFE0E0E0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <!-- Message and optional input -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,25">
                        <!-- Message -->
                        <TextBlock Text="{Binding Message}"
                                   FontSize="14"
                                   Foreground="#FFA0A0A0"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   Margin="0,0,0,20" />

                        <!-- Input field (visible only for input dialogs) -->
                        <TextBox x:Name="InputTextBox"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding ShowInput, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Background="#FF2D2D30"
                                 Foreground="#FFE0E0E0"
                                 BorderBrush="#FF555555"
                                 BorderThickness="1"
                                 Padding="12,10"
                                 FontSize="13"
                                 CaretBrush="#FF2196F3">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="#FF2196F3" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <!-- OK Button -->
                        <Button x:Name="OkButton"
                                Content="OK"
                                Click="OkButton_Click"
                                Visibility="{Binding ShowOkButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                Width="100"
                                Height="36"
                                Margin="0,0,8,0"
                                Style="{StaticResource DialogPrimaryButton}" />

                        <!-- Yes Button -->
                        <Button x:Name="YesButton"
                                Content="Yes"
                                Click="YesButton_Click"
                                Visibility="{Binding ShowYesButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                Width="100"
                                Height="36"
                                Margin="0,0,8,0"
                                Style="{StaticResource DialogPrimaryButton}" />

                        <!-- No Button -->
                        <Button x:Name="NoButton"
                                Content="No"
                                Click="NoButton_Click"
                                Visibility="{Binding ShowNoButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                Width="100"
                                Height="36"
                                Margin="0,0,8,0"
                                Style="{StaticResource DialogSecondaryButton}" />

                        <!-- Cancel Button -->
                        <Button x:Name="CancelButton"
                                Content="Cancel"
                                Click="CancelButton_Click"
                                Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                Width="100"
                                Height="36"
                                IsCancel="True"
                                Style="{StaticResource DialogSecondaryButton}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>