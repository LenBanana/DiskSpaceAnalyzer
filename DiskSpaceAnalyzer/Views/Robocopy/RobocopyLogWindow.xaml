<Window x:Class="DiskSpaceAnalyzer.Views.Robocopy.RobocopyLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:DiskSpaceAnalyzer.ViewModels"
        xmlns:converters="clr-namespace:DiskSpaceAnalyzer.Converters"
        mc:Ignorable="d"
        Title="Robocopy Output Log"
        Height="600" Width="900"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance viewModels:FileCopyViewModel, IsDesignTimeCreatable=False}"
        Background="#FF1E1E1E">

    <Window.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/RobocopyStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#FF252526"
                BorderBrush="#FF555555"
                BorderThickness="0,0,0,1"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Output Log"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Live output from robocopy process"
                               FontSize="11"
                               Foreground="#FFA0A0A0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Auto-scroll"
                              x:Name="AutoScrollCheckBox"
                              IsChecked="True"
                              Foreground="#FFE0E0E0"
                              VerticalAlignment="Center"
                              Margin="0,0,15,0"
                              ToolTip="Automatically scroll to show latest output" />

                    <Button Content="📄 Open Full Log"
                            Command="{Binding OpenLogFileCommand}"
                            Style="{StaticResource RobocopyButtonStyle}"
                            Padding="15,8"
                            FontSize="11"
                            Margin="0,0,8,0"
                            ToolTip="Open complete log file in default text editor" />

                    <Button Content="Copy All"
                            Click="CopyAllButton_Click"
                            Style="{StaticResource RobocopySecondaryButtonStyle}"
                            Padding="15,8"
                            FontSize="11"
                            ToolTip="Copy all visible log content to clipboard" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log Content -->
        <Border Grid.Row="1"
                Background="#FF1E1E1E"
                BorderBrush="#FF555555"
                BorderThickness="0"
                Padding="0">
            <TextBox x:Name="LogTextBox"
                     Text="{Binding LogOutput, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas, Courier New"
                     FontSize="11"
                     Background="Transparent"
                     Foreground="#FFA0A0A0"
                     BorderThickness="0"
                     Padding="15"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch" />
        </Border>

        <!-- Footer with Status -->
        <Border Grid.Row="2"
                Background="#FF252526"
                BorderBrush="#FF555555"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsLogTruncated, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="⚠️"
                               FontSize="12"
                               Foreground="#FFFF9800"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Showing last 1000 lines"
                               FontSize="11"
                               Foreground="#FFFF9800"
                               FontWeight="SemiBold"
                               Margin="0,0,15,0" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage, StringFormat='Status: {0}'}"
                           FontSize="11"
                           Foreground="#FFE0E0E0"
                           VerticalAlignment="Center"
                           Margin="10,0" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="11"
                               Foreground="#FF888888">
                        <Run Text="Lines: " />
                        <Run Text="{Binding LogLineCount, Mode=OneWay, StringFormat='{}{0:N0}'}" />
                    </TextBlock>
                    <TextBlock Text=" • "
                               FontSize="11"
                               Foreground="#FF555555"
                               Margin="6,0" />
                    <TextBlock FontSize="11"
                               Foreground="#FF888888">
                        <Run Text="{Binding LogOutput.Length, Mode=OneWay, StringFormat='{}{0:N0} chars'}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
