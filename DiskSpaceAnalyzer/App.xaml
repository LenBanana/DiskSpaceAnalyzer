<Application x:Class="DiskSpaceAnalyzer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DiskSpaceAnalyzer.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:IndexToDepthConverter x:Key="IndexToDepthConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
